# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:pass@host/yadahworld?sslmode=require"

# Auth (admin)
NEXTAUTH_SECRET="generate: openssl rand -base64 32"
# Required for admin image uploads (JWT on /api/admin/upload) — must match the secret used at login.
NEXTAUTH_URL="http://localhost:3000"
ADMIN_EMAIL="admin@yadahworld.com"
# bcrypt hash of "ChangeMe123!" (generate your own before production)
ADMIN_PASSWORD="$2b$12$qGJADOuBPB6K19KbfLySuOVkIg9mH4L.in8/ojgCKAx8Tj8Il.0/i"

# Cloudinary (image uploads from Admin use the server API secret; the public site only needs the cloud name for URLs)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_key"
CLOUDINARY_API_SECRET="your_secret"

# Brevo SMTP (Nodemailer)
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_login_email
BREVO_SMTP_PASS=your_brevo_smtp_key
BREVO_FROM_EMAIL=noreply@yadahworld.com
BREVO_FROM_NAME=Yadah
BREVO_NOTIFY_EMAIL=yadahsings@gmail.com

# Brevo REST API (newsletter list + transactional templates — separate from BREVO_SMTP_PASS)
BREVO_API_KEY=your_brevo_api_key
BREVO_LIST_ID=your_brevo_list_id
BREVO_WELCOME_TEMPLATE_ID=optional_template_id

# Paystack (event ticketing — registration API returns 503 if secret unset for paid tiers)
PAYSTACK_SECRET_KEY=sk_live_xxxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_xxxx
# Optional: Paystack Dashboard → Settings → Webhooks → signing secret (falls back to PAYSTACK_SECRET_KEY)
