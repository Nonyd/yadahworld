generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BookingRequest {
  id                 String        @id @default(cuid())
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  fullName           String
  email              String
  phone              String
  churchName         String
  website            String?
  orgAddress         String
  orgPhone           String
  orgEmail           String
  eventName          String
  natureOfEvent      String
  whatExpected       String
  expectationDetails String
  eventDate          DateTime
  eventTime          String
  eventAddress       String
  additionalInfo     String?
  status             BookingStatus @default(PENDING)
  adminNotes         String?       @map("notes")
}

model ContactMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
}

model Product {
  id          String      @id @default(cuid())
  createdAt   DateTime    @default(now())
  name        String
  description String?
  price       Int
  currency    String      @default("NGN")
  images      String[]
  category    String?
  inStock     Boolean     @default(true)
  stripeId    String?
  slug        String      @unique
  orders      OrderItem[]
}

model Order {
  id                String      @id @default(cuid())
  createdAt         DateTime    @default(now())
  customerName      String
  customerEmail     String
  amount            Int
  currency          String
  status            OrderStatus @default(PENDING)
  stripePaymentId   String?
  items             OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Int
}

model SiteSettings {
  id        Int      @id @default(1)
  updatedAt DateTime @updatedAt

  siteName        String  @default("Yadah")
  siteTagline     String?
  metaDescription String?
  metaTitleSuffix String? @default("| Yadah")

  contactEmail String?
  contactPhone String?
  bookingEmail String?

  socialInstagram String?
  socialYoutube   String?
  socialSpotify   String?
  socialFacebook  String?
  socialX         String?

  /// Site logo (same asset as public navbar when set; falls back to default Cloudinary logo)
  imageSiteLogo      String?
  imageHero          String?
  imageEditorial     String?
  imageAboutHero     String?
  imageAboutPortrait String?
  imageWorshipBg     String?

  /// Large portrait beside copy on /campus-tour
  imageCampusTourPortrait String?

  /// Top marquee row on /campus-tour (scrolls one direction)
  campusTourMarquee1Urls String[] @default([])
  /// Bottom marquee row (scrolls opposite direction)
  campusTourMarquee2Urls String[] @default([])

  galleryImageUrls String[] @default([])

  socialTiktok String?

  paystackPublicKey    String?
  paystackSecretKey    String?
  paystackEnabled      Boolean @default(false)
  flutterwavePublicKey String?
  flutterwaveSecretKey String?
  flutterwaveEnabled   Boolean @default(false)
  stripeEnabled         Boolean @default(false)
  stripeSecretKey       String?
  stripePublishableKey  String?
  stripeWebhookSecret   String?

  brevoSmtpHost    String?
  brevoSmtpPort    Int?
  brevoSmtpUser    String?
  brevoSmtpPass    String?
  brevoFromEmail   String?
  brevoFromName    String?
  brevoNotifyEmail String?

  heroTagline       String?
  aboutBioShort     String?
  footerCopyright   String?
  locationDisplay   String?

  /// Merged with code defaults — editable page/section copy (nested JSON)
  siteContentJson Json?
}

enum PlaylistSlot {
  MUSIC_VIDEOS
  MINISTRATIONS
  GENERAL
}

model YouTubePlaylist {
  id                String         @id @default(cuid())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  name              String
  youtubePlaylistId String         @unique
  slot              PlaylistSlot   @default(GENERAL)
  maxVideos         Int            @default(50)
  isActive          Boolean        @default(true)
  lastSyncedAt      DateTime?
  videos            CachedVideo[]
}

model CachedVideo {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  youtubeVideoId String          @unique
  title          String
  description    String?         @db.Text
  thumbnailUrl   String
  publishedAt    DateTime
  duration       String?
  viewCount      String?
  isActive       Boolean         @default(true)
  isFeatured     Boolean         @default(false)
  featuredOrder  Int?
  playlistId     String
  playlist       YouTubePlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
}

model SiteRelease {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  title       String
  slug        String   @unique
  description String?
  feat        String?
  type        String
  year        String
  cover       String
  spotify            String?
  spotifyEmbed       String?
  apple              String?
  youtube            String?
  musicVideoYoutube  String?
  /// Extra listen links: `[{ "label": "Audiomack", "url": "https://..." }, ...]`. Shown as buttons after Spotify/Apple/YouTube.
  streamingLinks     Json?
  isNew              Boolean  @default(false)
  /// Display order on the homepage among releases with `showOnHomepage` (lower first).
  order              Int      @default(0)
  /// Exact release date — drives sorting on /releases (newest first).
  releasedAt         DateTime @default(now())
  /// When true, this release appears in the homepage music grid (order controlled by `order`).
  showOnHomepage     Boolean  @default(true)
}

model SiteEvent {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  title       String
  description String?
  date        DateTime
  /// Shown on the public site instead of the formatted calendar date when set (e.g. TBA).
  dateCaption String?
  location    String
  link        String?
  isActive    Boolean  @default(true)
}

enum BookingStatus {
  PENDING
  REVIEWING
  CONFIRMED
  DECLINED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
}

model NewsletterSubscriber {
  id          String           @id @default(cuid())
  createdAt   DateTime         @default(now())
  email       String           @unique
  name        String?
  status      SubscriberStatus @default(ACTIVE)
  brevoSynced Boolean          @default(false)
  /// Where they signed up (e.g. footer)
  source      String?          @default("footer")
}

enum EventStatus {
  DRAFT
  COMING_SOON
  PUBLISHED
  CANCELLED
  PAST
}

enum PaymentStatus {
  PENDING
  PAID
  FREE
  FAILED
  REFUNDED
}

enum EventType {
  PHYSICAL
  ONLINE
  HYBRID
}

enum CampusTourStatus {
  NEW
  REVIEWING
  CONFIRMED
  DECLINED
}

model CampusTourApplication {
  id            String           @id @default(cuid())
  createdAt     DateTime         @default(now())
  fullName      String
  whatsapp      String
  email         String
  campus        String
  customCampus  String?
  role          String
  customRole    String?
  expectations  String?          @db.Text
  status        CampusTourStatus @default(NEW)
}

model Event {
  id            String                @id @default(cuid())
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  title         String
  slug          String                @unique
  description   String?               @db.Text
  date          DateTime
  endDate       DateTime?
  doorsOpen     String?
  timezone      String                @default("Africa/Lagos")
  type          EventType             @default(PHYSICAL)
  venueName     String?
  venueAddress  String?
  venueCity     String?
  venueCountry  String                @default("Nigeria")
  isOnline      Boolean               @default(false)
  streamUrl     String?
  bannerImage   String?
  dressCode     String?
  requirements  String?               @db.Text
  status        EventStatus           @default(DRAFT)
  isFeatured    Boolean               @default(false)
  totalCapacity Int?
  registrations EventRegistration[]
  tiers         TicketTier[]
  speakers      EventSpeaker[]
  interests     EventInterest[]
}

model EventInterest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  email     String
  name      String?
  notified  Boolean  @default(false)

  @@unique([eventId, email])
}

model EventSpeaker {
  id      String  @id @default(cuid())
  eventId String
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name    String
  role    String?
  bio     String?
  photo   String?
  order   Int     @default(0)
}

model TicketTier {
  id              String                @id @default(cuid())
  createdAt       DateTime              @default(now())
  eventId         String
  event           Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  price           Int                   @default(0)
  currency        String                @default("NGN")
  capacity        Int?
  sold            Int                   @default(0)
  isActive        Boolean               @default(true)
  registrations   EventRegistration[]
}

model EventRegistration {
  id              String        @id @default(cuid())
  createdAt       DateTime      @default(now())
  eventId         String
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tierId          String
  tier            TicketTier    @relation(fields: [tierId], references: [id])
  fullName        String
  email           String
  phone           String
  amount          Int           @default(0)
  currency        String        @default("NGN")
  paymentStatus   PaymentStatus @default(PENDING)
  paymentRef      String?       @unique
  paymentProvider String?
  ticketCode      String        @unique @default(cuid())
  qrCodeUrl       String?
  checkedIn       Boolean       @default(false)
  checkedInAt     DateTime?
  checkedInBy     String?
  source          String        @default("web")
}
