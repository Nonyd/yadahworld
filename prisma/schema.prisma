generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BookingRequest {
  id                 String        @id @default(cuid())
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  fullName           String
  email              String
  phone              String
  churchName         String
  website            String?
  orgAddress         String
  orgPhone           String
  orgEmail           String
  eventName          String
  natureOfEvent      String
  whatExpected       String
  expectationDetails String
  eventDate          DateTime
  eventTime          String
  eventAddress       String
  additionalInfo     String?
  status             BookingStatus @default(PENDING)
  adminNotes         String?       @map("notes")
  declineReason      String?
  confirmationNote   String?
  lastStatusEmailSentAt DateTime?
  replies            BookingReply[]
}

model ContactMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  replies   ContactMessageReply[]
}

model BookingReply {
  id               String         @id @default(cuid())
  createdAt        DateTime       @default(now())
  bookingRequestId String
  bookingRequest   BookingRequest @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  subject          String
  message          String
  sentByEmail      String?
}

model ContactMessageReply {
  id               String         @id @default(cuid())
  createdAt        DateTime       @default(now())
  contactMessageId String
  contactMessage   ContactMessage @relation(fields: [contactMessageId], references: [id], onDelete: Cascade)
  subject          String
  message          String
  sentByEmail      String?
}

model Product {
  id            String           @id @default(cuid())
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @default(now()) @updatedAt
  name          String
  slug          String           @unique
  description   String?
  type          ProductType      @default(PHYSICAL)
  price         Int // kobo (NGN smallest unit)
  comparePrice  Int?
  images        String[]
  isActive      Boolean          @default(true)
  isFeatured    Boolean          @default(false)
  category      String?
  tags          String[]         @default([])
  digitalFile   String?
  variants      ProductVariant[]
  orders        OrderItem[]
}

enum ProductType {
  PHYSICAL
  DIGITAL
  BOOK
}

model ProductVariant {
  id        String      @id @default(cuid())
  productId String
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  value     String
  stock     Int         @default(0)
  price     Int?
  sku       String?
  orders    OrderItem[]
}

model Order {
  id              String            @id @default(cuid())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  orderNumber     String            @unique
  status          OrderStatus       @default(PENDING)
  customerName    String
  customerEmail   String
  customerPhone   String?
  shippingAddress Json?
  items           OrderItem[]
  subtotal        Int
  shippingFee     Int               @default(0)
  discount        Int               @default(0)
  total           Int
  paymentGateway  String?
  paymentRef      String?
  paymentStatus   ShopPaymentStatus @default(UNPAID)
  notes             String?
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  /// JSON array: [{ "status": "SHIPPED", "at": "ISO8601", "note": "..." }]
  statusHistory     Json?
  lastStatusEmailAt DateTime?
  checkoutSession ShopCheckoutSession?
}

/// Binds a payment gateway reference to a server-validated cart snapshot until the order is created after payment.
model ShopCheckoutSession {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  reference    String    @unique
  gateway      String
  linesJson    Json
  customerJson Json
  shippingJson Json?
  subtotal     Int
  shippingFee  Int
  total        Int
  orderId      String?   @unique
  order        Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
}

model OrderItem {
  id             String          @id @default(cuid())
  orderId        String
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String
  product        Product         @relation(fields: [productId], references: [id])
  variantId      String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id])
  quantity       Int
  price          Int
  name           String
  variantLabel   String?
}

model SiteSettings {
  id        Int      @id @default(1)
  updatedAt DateTime @updatedAt

  siteName        String  @default("Yadah")
  siteTagline     String?
  metaDescription String?
  metaTitleSuffix String? @default("| Yadah")

  contactEmail String?
  contactPhone String?
  bookingEmail String?

  socialInstagram String?
  socialYoutube   String?
  socialSpotify   String?
  socialFacebook  String?
  socialX         String?

  /// Site logo (same asset as public navbar when set; falls back to default Cloudinary logo)
  imageSiteLogo      String?
  imageHero          String?
  imageEditorial     String?
  imageAboutHero     String?
  imageAboutPortrait String?
  imageWorshipBg     String?

  /// Large portrait beside copy on /campus-tour
  imageCampusTourPortrait String?

  /// Top marquee row on /campus-tour (scrolls one direction)
  campusTourMarquee1Urls String[] @default([])
  /// Bottom marquee row (scrolls opposite direction)
  campusTourMarquee2Urls String[] @default([])

  galleryImageUrls String[] @default([])

  socialTiktok String?

  paystackPublicKey     String?
  paystackSecretKey     String?
  paystackEnabled       Boolean @default(false)
  paystackMode          String  @default("test") // "test" | "live"
  paystackWebhookSecret String?

  flutterwavePublicKey      String?
  flutterwaveSecretKey      String?
  flutterwaveEnabled        Boolean @default(false)
  flutterwaveMode           String  @default("test") // "test" | "live"
  flutterwaveWebhookSecret  String?

  payazaPublicKey     String?
  payazaSecretKey     String?
  payazaEnabled       Boolean @default(false)
  payazaMode          String  @default("test") // "test" | "live"
  payazaWebhookSecret String?
  stripeEnabled         Boolean @default(false)
  stripeSecretKey       String?
  stripePublishableKey  String?
  stripeWebhookSecret   String?

  brevoSmtpHost    String?
  brevoSmtpPort    Int?
  brevoSmtpUser    String?
  brevoSmtpPass    String?
  brevoFromEmail   String?
  brevoFromName    String?
  brevoNotifyEmail String?

  heroTagline       String?
  aboutBioShort     String?
  footerCopyright   String?
  locationDisplay   String?

  /// Merged with code defaults — editable page/section copy (nested JSON)
  siteContentJson Json?
  /// order subtotal in kobo above which shipping is free (null = never free)
  freeShippingThreshold Int?
  /// fallback shipping rate in kobo
  defaultShippingRate   Int      @default(150000)
}

model ShippingRate {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  /// Nigerian state name, "International", or "Default"
  zone      String   @unique
  /// Display name e.g. "Lagos", "International"
  label     String
  /// shipping fee in kobo
  rate      Int
  isActive  Boolean  @default(true)
}

enum PlaylistSlot {
  MUSIC_VIDEOS
  MINISTRATIONS
  GENERAL
}

model YouTubePlaylist {
  id                String         @id @default(cuid())
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  name              String
  youtubePlaylistId String         @unique
  slot              PlaylistSlot   @default(GENERAL)
  maxVideos         Int            @default(50)
  isActive          Boolean        @default(true)
  lastSyncedAt      DateTime?
  videos            CachedVideo[]
}

model CachedVideo {
  id             String          @id @default(cuid())
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  youtubeVideoId String          @unique
  title          String
  description    String?         @db.Text
  thumbnailUrl   String
  publishedAt    DateTime
  duration       String?
  viewCount      String?
  isActive       Boolean         @default(true)
  isFeatured     Boolean         @default(false)
  featuredOrder  Int?
  playlistId     String
  playlist       YouTubePlaylist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
}

model SiteRelease {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  title       String
  slug        String   @unique
  description String?
  feat        String?
  type        String
  year        String
  cover       String
  spotify            String?
  spotifyEmbed       String?
  apple              String?
  youtube            String?
  musicVideoYoutube  String?
  /// Extra listen links: `[{ "label": "Audiomack", "url": "https://..." }, ...]`. Shown as buttons after Spotify/Apple/YouTube.
  streamingLinks     Json?
  isNew              Boolean  @default(false)
  /// Display order on the homepage among releases with `showOnHomepage` (lower first).
  order              Int      @default(0)
  /// Exact release date — drives sorting on /releases (newest first).
  releasedAt         DateTime @default(now())
  /// When true, this release appears in the homepage music grid (order controlled by `order`).
  showOnHomepage     Boolean  @default(true)
}

model SiteEvent {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  title       String
  description String?
  date        DateTime
  /// Shown on the public site instead of the formatted calendar date when set (e.g. TBA).
  dateCaption String?
  location    String
  link        String?
  isActive    Boolean  @default(true)
}

enum BookingStatus {
  PENDING
  REVIEWING
  CONFIRMED
  DECLINED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum ShopPaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
}

model NewsletterSubscriber {
  id          String           @id @default(cuid())
  createdAt   DateTime         @default(now())
  email       String           @unique
  name        String?
  status      SubscriberStatus @default(ACTIVE)
  brevoSynced Boolean          @default(false)
  /// Where they signed up (e.g. footer)
  source      String?          @default("footer")
}

enum EventStatus {
  DRAFT
  COMING_SOON
  PUBLISHED
  CANCELLED
  PAST
}

enum PaymentStatus {
  PENDING
  PAID
  FREE
  FAILED
  REFUNDED
  WAITLISTED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum EventType {
  PHYSICAL
  ONLINE
  HYBRID
}

enum CampusTourStatus {
  NEW
  REVIEWING
  CONFIRMED
  DECLINED
}

model CampusTourApplication {
  id                 String           @id @default(cuid())
  createdAt          DateTime         @default(now())
  fullName           String
  whatsapp           String
  email              String
  campus             String
  customCampus       String?
  role               String
  customRole         String?
  whyMinisterYadah   String?          @db.Text
  expectations       String?          @db.Text
  status             CampusTourStatus @default(NEW)
}

model Event {
  id               String              @id @default(cuid())
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  title            String
  slug             String              @unique
  description      String?             @db.Text
  bodyHtml         String?             @db.Text
  date             DateTime
  endDate          DateTime?
  doorsOpen        String?
  timezone         String              @default("Africa/Lagos")
  type             EventType           @default(PHYSICAL)
  venueName        String?
  venueAddress     String?
  venueCity        String?
  venueCountry     String              @default("Nigeria")
  isOnline         Boolean             @default(false)
  streamUrl        String?
  bannerImage      String?
  thumbnailImage   String?
  dressCode        String?
  requirements     String?             @db.Text
  status           EventStatus         @default(DRAFT)
  isFeatured       Boolean             @default(false)
  totalCapacity    Int?
  isRecurring      Boolean             @default(false)
  recurringPattern Json?
  parentEventId    String?
  parentEvent      Event?              @relation("EventSeries", fields: [parentEventId], references: [id], onDelete: SetNull)
  childEvents      Event[]             @relation("EventSeries")
  registrations    EventRegistration[]
  tiers            TicketTier[]
  speakers         EventSpeaker[]
  interests        EventInterest[]
  promoCodes       PromoCode[]
}

model EventInterest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  email     String
  name      String?
  notified  Boolean  @default(false)

  @@unique([eventId, email])
}

model EventSpeaker {
  id      String  @id @default(cuid())
  eventId String
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name    String
  role    String?
  bio     String?
  photo   String?
  order   Int     @default(0)
}

model TicketTier {
  id            String              @id @default(cuid())
  createdAt     DateTime            @default(now())
  eventId       String
  event         Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  price         Int                 @default(0)
  currency      String              @default("NGN")
  capacity      Int?
  sold          Int                 @default(0)
  isActive      Boolean             @default(true)
  salesStart    DateTime?
  salesEnd      DateTime?
  perks         String[]            @default([])
  sortOrder     Int                 @default(0)
  registrations EventRegistration[]
}

model PromoCode {
  id            String       @id @default(cuid())
  createdAt     DateTime     @default(now())
  eventId       String
  event         Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  code          String
  discountType  DiscountType @default(PERCENTAGE)
  discountValue Int
  maxUses       Int?
  usedCount     Int          @default(0)
  expiresAt     DateTime?
  isActive      Boolean      @default(true)

  @@unique([eventId, code])
}

model EventRegistration {
  id                   String        @id @default(cuid())
  createdAt            DateTime      @default(now())
  eventId              String
  event                Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tierId               String
  tier                 TicketTier    @relation(fields: [tierId], references: [id])
  fullName             String
  email                String
  phone                String
  quantity             Int           @default(1)
  amount               Int           @default(0)
  currency             String        @default("NGN")
  paymentStatus        PaymentStatus @default(PENDING)
  paymentRef           String?
  paymentProvider      String?
  ticketCode           String        @unique @default(cuid())
  qrCodeUrl            String?
  checkedIn            Boolean       @default(false)
  checkedInAt          DateTime?
  checkedInBy          String?
  source               String        @default("web")
  promoCode            String?
  discountAmount       Int           @default(0)
  isWaitlisted         Boolean       @default(false)
  waitlistPos          Int?
  waitlistClaimToken   String?       @unique
  waitlistClaimExpires DateTime?
  orderGroupId         String?
}

/// Append-only audit trail written from admin API route handlers after successful actions.
model AdminActivityLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  method     String
  path       String
  actorEmail String?
  actorId    String?
  ipAddress  String?

  @@index([createdAt(sort: Desc)])
}
